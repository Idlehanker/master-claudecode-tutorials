{
	"hooks": {
		"Notification": [{
			"matcher": "",
			"hooks": [{
				"type": "command",
				"command": "notify-send 'Claude Code' 'Claude Code needs your attention'"
			}]
		}],
		"PostToolUse": [{
			"matcher": "Edit|Write",
			"hooks": [{
				"type": "command",
				"command": "jq -r '.tools_input.file_path' | xargs npx prettier --write"
			}]
		}],
		"PreToolUse": [{
			"matcher": "Edit|Write",
			"hooks": [{
				"type": "command",
				"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/process_files.sh"
			}]
		}]
	},
	"permissions": {
		"allow": [
			"Bash(curl -s *)",
			"Bash(curl -v *)"
		]
	}
}